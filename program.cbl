 IDENTIFICATION DIVISION.
 PROGRAM-ID. PAYROLL-SYSTEM.
 AUTHOR. PAYROLL-DEPT.

 ENVIRONMENT DIVISION.
 CONFIGURATION SECTION.
 SOURCE-COMPUTER. LINUX.
 OBJECT-COMPUTER. LINUX.
 INPUT-OUTPUT SECTION.
 FILE-CONTROL.
     SELECT EMPLOYEE-FILE
         ASSIGN TO "employees_input.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-EMP-STATUS.
     SELECT PAYSLIP-FILE
         ASSIGN TO "payslips_output.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-PAY-STATUS.
     SELECT REJECT-FILE
         ASSIGN TO "rejects_output.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-REJ-STATUS.
     SELECT REPORT-FILE
         ASSIGN TO "report_output.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-RPT-STATUS.

 DATA DIVISION.
 FILE SECTION.

 FD EMPLOYEE-FILE
     RECORD CONTAINS 37 CHARACTERS.
 01 EMPLOYEE-RECORD.
     05 EMP-ID              PIC 9(6).
     05 EMP-ID-X            REDEFINES EMP-ID PIC X(6).
     05 EMP-NAME            PIC X(20).
     05 EMP-CATEGORY        PIC X(1).
     05 EMP-HOURS-WORKED    PIC 9(3)V9(1).
     05 EMP-HOURLY-RATE     PIC 9(4)V9(2).

 FD PAYSLIP-FILE
     RECORD CONTAINS 123 CHARACTERS.
 01 PAYSLIP-RECORD          PIC X(123).

 FD REJECT-FILE
     RECORD CONTAINS 45 CHARACTERS.
 01 REJECT-RECORD           PIC X(45).

 FD REPORT-FILE
     RECORD CONTAINS 70 CHARACTERS.
 01 REPORT-RECORD            PIC X(70).

 WORKING-STORAGE SECTION.

 01 WS-FILE-STATUS.
     05 WS-EMP-STATUS       PIC X(2).
         88 EMP-FILE-OK     VALUE "00".
         88 EMP-EOF         VALUE "10".
     05 WS-PAY-STATUS       PIC X(2).
         88 PAY-FILE-OK     VALUE "00".
     05 WS-REJ-STATUS       PIC X(2).
         88 REJ-FILE-OK     VALUE "00".
     05 WS-RPT-STATUS       PIC X(2).
         88 RPT-FILE-OK     VALUE "00".

 01 WS-FLAGS.
     05 WS-END-OF-FILE      PIC X(1) VALUE "N".
         88 END-OF-FILE     VALUE "Y".
         88 NOT-END-OF-FILE VALUE "N".

 01 WS-VALIDATION.
     05 WS-RECORD-VALID     PIC X(1) VALUE "Y".
         88 RECORD-VALID    VALUE "Y".
         88 RECORD-INVALID  VALUE "N".
     05 WS-VALIDATION-CODE  PIC X(7) VALUE SPACES.

 01 WS-COMPUTATION.
     05 WS-REGULAR-HOURS    PIC 9(3)V9(1) VALUE ZEROES.
     05 WS-OVERTIME-HOURS   PIC 9(3)V9(1) VALUE ZEROES.
     05 WS-REGULAR-PAY      PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-OVERTIME-PAY     PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-GROSS-SALARY     PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-OVERTIME-RATE    PIC 9(4)V9(4) VALUE ZEROES.
     05 WS-BONUS-FACTOR     PIC 9(1)V9(2) VALUE ZEROES.
     05 WS-HEALTH-DEDUCTION PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-RETIRE-DEDUCTION PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-UNEMP-DEDUCTION  PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-TOTAL-DEDUCTION  PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-NET-SALARY       PIC 9(7)V9(2) VALUE ZEROES.

 01 WS-LIMITS.
     05 WS-STANDARD-HOURS   PIC 9(3)V9(1) VALUE 35.0.

 01 WS-CONTRIB-RATES.
     05 WS-HEALTH-RATE      PIC V9(4) VALUE .0730.
     05 WS-RETIRE-RATE      PIC V9(4) VALUE .0690.
     05 WS-UNEMP-RATE       PIC V9(4) VALUE .0240.

 01 WS-TOTALS.
     05 WS-TOTAL-EMPLOYEES  PIC 9(6) VALUE ZEROES.
     05 WS-TOTAL-REJECTED   PIC 9(6) VALUE ZEROES.
     05 WS-TOTAL-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-TOTAL-NET        PIC 9(9)V9(2) VALUE ZEROES.

 01 WS-CAT-SUBTOTALS.
     05 WS-CAT-A-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-A-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-A-NET        PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-B-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-B-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-B-NET        PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-C-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-C-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-C-NET        PIC 9(9)V9(2) VALUE ZEROES.

 01 WS-CATEGORY-TABLE.
     05 WS-CAT-ENTRY OCCURS 3 TIMES INDEXED BY WS-CAT-IDX.
         10 WS-CAT-LABEL    PIC X(1).
         10 WS-CAT-COUNT    PIC 9(6).
         10 WS-CAT-TOTAL    PIC 9(9)V9(2).
         10 WS-CAT-NET-TOT  PIC 9(9)V9(2).

 01 WS-CAT-REPORT-LINE.
     05 FILLER              PIC X(9)  VALUE "CATEGORY ".
     05 WCR-LABEL           PIC X(1).
     05 FILLER              PIC X(13) VALUE " - EMPLOYEES:".
     05 WCR-COUNT           PIC ZZ,ZZZ,ZZ9.
     05 FILLER              PIC X(9)  VALUE " PAYROLL:".
     05 WCR-TOTAL           PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-LOOP-INDEX           PIC 9(2) VALUE 1.

 01 WS-CATEGORY-FLAGS.
     05 WS-CAT              PIC X(1) VALUE SPACES.
         88 CATEGORY-A      VALUE "A".
         88 CATEGORY-B      VALUE "B".
         88 CATEGORY-C      VALUE "C".

 01 WS-PAYSLIP-LINE.
     05 WSP-ID              PIC 9(6).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-NAME            PIC X(20).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-CATEGORY        PIC X(1).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-HOURS           PIC ZZZ.9.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-RATE            PIC ZZZZ.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-REGULAR         PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-OVERTIME        PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-GROSS           PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-HEALTH          PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-RETIREMENT      PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-UNEMPLOYMENT    PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-TOTAL-DED       PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-NET             PIC ZZZZZ9.99.

 01 WS-REJECT-LINE.
     05 WRJ-EMP-DATA        PIC X(37).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WRJ-ERROR-CODE      PIC X(7).

 01 WS-RPT-HEADER.
     05 FILLER              PIC X(10) VALUE "CATEGORY  ".
     05 FILLER              PIC X(12) VALUE "EMPLOYEES   ".
     05 FILLER              PIC X(20) VALUE "GROSS PAYROLL       ".
     05 FILLER              PIC X(20) VALUE "NET PAYROLL         ".
     05 FILLER              PIC X(8)  VALUE SPACES.

 01 WS-RPT-SEPARATOR.
     05 FILLER              PIC X(70)
         VALUE ALL "-".

 01 WS-RPT-CAT-LINE.
     05 FILLER              PIC X(5)  VALUE "  ".
     05 WRC-LABEL           PIC X(1).
     05 FILLER              PIC X(4)  VALUE SPACES.
     05 WRC-COUNT           PIC ZZ,ZZZ,ZZ9.
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 WRC-GROSS           PIC ZZ,ZZZ,ZZZ,ZZ9.99.
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 WRC-NET             PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-RPT-GRAND-LINE.
     05 FILLER              PIC X(10) VALUE "TOTAL     ".
     05 WRG-COUNT           PIC ZZ,ZZZ,ZZ9.
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 WRG-GROSS           PIC ZZ,ZZZ,ZZZ,ZZ9.99.
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 WRG-NET             PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-TOTAL-DISP.
     05 FILLER              PIC X(30)
         VALUE "EMPLOYEES VALID (PROCESSED) : ".
     05 WS-TOT-EMP-DISP     PIC ZZ,ZZZ,ZZ9.

 01 WS-REJECTED-DISP.
     05 FILLER              PIC X(30)
         VALUE "EMPLOYEES REJECTED          : ".
     05 WS-TOT-REJ-DISP     PIC ZZ,ZZZ,ZZ9.

 01 WS-PAYROLL-DISP.
     05 FILLER              PIC X(30)
         VALUE "TOTAL GROSS PAYROLL         : ".
     05 WS-TOT-PAY-DISP     PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-NET-PAYROLL-DISP.
     05 FILLER              PIC X(30)
         VALUE "TOTAL NET PAYROLL           : ".
     05 WS-TOT-NET-DISP     PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-SEPARATOR.
     05 FILLER              PIC X(60)
         VALUE "------------------------------------------------------------".

 01 WS-HEADER-LINE.
     05 FILLER              PIC X(60)
         VALUE "           PAYROLL PROCESSING REPORT                       ".

 01 WS-COL-HEADER.
     05 FILLER              PIC X(6)  VALUE "EMP-ID".
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 FILLER              PIC X(20) VALUE "NAME                ".
     05 FILLER              PIC X(4)  VALUE "CAT ".
     05 FILLER              PIC X(8)  VALUE "HOURS   ".
     05 FILLER              PIC X(8)  VALUE "RATE    ".
     05 FILLER              PIC X(12) VALUE "GROSS SALARY".
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 FILLER              PIC X(10) VALUE "NET SALARY".

 01 WS-DISPLAY-LINE.
     05 WSD-ID              PIC 9(6).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-NAME            PIC X(20).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-CATEGORY        PIC X(1).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-HOURS           PIC ZZ9.9.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-RATE            PIC ZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-GROSS           PIC ZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-NET             PIC ZZZZ9.99.

 PROCEDURE DIVISION.

 0000-MAIN-CONTROL.
     PERFORM 1000-INITIALIZATION
     PERFORM 2000-PROCESS-EMPLOYEES
         UNTIL END-OF-FILE
     PERFORM 3000-FINALIZATION
     STOP RUN.

 1000-INITIALIZATION.
     OPEN INPUT EMPLOYEE-FILE
     IF NOT EMP-FILE-OK
         DISPLAY "ERROR: Cannot open employees_input.dat - Status: "
             WS-EMP-STATUS
         STOP RUN
     END-IF
     OPEN OUTPUT PAYSLIP-FILE
     IF NOT PAY-FILE-OK
         DISPLAY "ERROR: Cannot open payslips_output.dat - Status: "
             WS-PAY-STATUS
         STOP RUN
     END-IF
     OPEN OUTPUT REJECT-FILE
     IF NOT REJ-FILE-OK
         DISPLAY "ERROR: Cannot open rejects_output.dat - Status: "
             WS-REJ-STATUS
         STOP RUN
     END-IF
     OPEN OUTPUT REPORT-FILE
     IF NOT RPT-FILE-OK
         DISPLAY "ERROR: Cannot open report_output.dat - Status: "
             WS-RPT-STATUS
         STOP RUN
     END-IF
     DISPLAY WS-SEPARATOR
     DISPLAY WS-HEADER-LINE
     DISPLAY WS-SEPARATOR
     DISPLAY WS-COL-HEADER
     DISPLAY WS-SEPARATOR
     PERFORM 1100-READ-EMPLOYEE.

 1100-READ-EMPLOYEE.
     READ EMPLOYEE-FILE INTO EMPLOYEE-RECORD
     IF EMP-EOF
         MOVE "Y" TO WS-END-OF-FILE
     ELSE
         IF NOT EMP-FILE-OK
             DISPLAY "ERROR: Read error - Status: " WS-EMP-STATUS
             MOVE "Y" TO WS-END-OF-FILE
         END-IF
     END-IF.

 2000-PROCESS-EMPLOYEES.
     PERFORM 1900-VALIDATE-RECORD
     IF RECORD-VALID
         PERFORM 2100-CALCULATE-SALARY
         PERFORM 2150-CALCULATE-DEDUCTIONS
         PERFORM 2200-WRITE-PAYSLIP
         PERFORM 2300-DISPLAY-EMPLOYEE
         ADD 1 TO WS-TOTAL-EMPLOYEES
         ADD WS-GROSS-SALARY TO WS-TOTAL-PAYROLL
         ADD WS-NET-SALARY   TO WS-TOTAL-NET
         PERFORM 2400-ACCUMULATE-CATEGORY
     ELSE
         PERFORM 1950-WRITE-REJECT
     END-IF
     PERFORM 1100-READ-EMPLOYEE.

 1900-VALIDATE-RECORD.
     MOVE "Y" TO WS-RECORD-VALID
     MOVE SPACES TO WS-VALIDATION-CODE
     MOVE EMP-CATEGORY TO WS-CAT
     EVALUATE TRUE
         WHEN EMP-ID-X = SPACES OR EMP-ID-X = "000000"
             MOVE "N"       TO WS-RECORD-VALID
             MOVE "ERR-001" TO WS-VALIDATION-CODE
         WHEN EMP-HOURS-WORKED <= ZEROES
           OR EMP-HOURS-WORKED > 80
             MOVE "N"       TO WS-RECORD-VALID
             MOVE "ERR-002" TO WS-VALIDATION-CODE
         WHEN EMP-HOURLY-RATE <= ZEROES
           OR EMP-HOURLY-RATE > 999.99
             MOVE "N"       TO WS-RECORD-VALID
             MOVE "ERR-003" TO WS-VALIDATION-CODE
         WHEN NOT (CATEGORY-A OR CATEGORY-B OR CATEGORY-C)
             MOVE "N"       TO WS-RECORD-VALID
             MOVE "ERR-004" TO WS-VALIDATION-CODE
     END-EVALUATE.

 1950-WRITE-REJECT.
     MOVE EMPLOYEE-RECORD   TO WRJ-EMP-DATA
     MOVE WS-VALIDATION-CODE TO WRJ-ERROR-CODE
     WRITE REJECT-RECORD FROM WS-REJECT-LINE
     IF NOT REJ-FILE-OK
         DISPLAY "ERROR: Reject write error - Status: "
             WS-REJ-STATUS
     END-IF
     ADD 1 TO WS-TOTAL-REJECTED
     DISPLAY "REJECTED [" WS-VALIDATION-CODE "]: "
         EMP-ID SPACE EMP-NAME.

 2100-CALCULATE-SALARY.
     MOVE EMP-CATEGORY TO WS-CAT
     MOVE ZEROES TO WS-REGULAR-PAY
     MOVE ZEROES TO WS-OVERTIME-PAY
     MOVE ZEROES TO WS-GROSS-SALARY
     MOVE ZEROES TO WS-OVERTIME-HOURS
     MOVE ZEROES TO WS-REGULAR-HOURS
     MOVE ZEROES TO WS-BONUS-FACTOR
     EVALUATE TRUE
         WHEN EMP-HOURS-WORKED > WS-STANDARD-HOURS
             COMPUTE WS-REGULAR-HOURS =
                 WS-STANDARD-HOURS
             COMPUTE WS-OVERTIME-HOURS =
                 EMP-HOURS-WORKED - WS-STANDARD-HOURS
             COMPUTE WS-REGULAR-PAY =
                 WS-REGULAR-HOURS * EMP-HOURLY-RATE
             EVALUATE TRUE
                 WHEN CATEGORY-A
                     MOVE 1.20 TO WS-BONUS-FACTOR
                 WHEN CATEGORY-B
                     MOVE 1.10 TO WS-BONUS-FACTOR
                 WHEN CATEGORY-C
                     MOVE 1.00 TO WS-BONUS-FACTOR
                 WHEN OTHER
                     MOVE 1.00 TO WS-BONUS-FACTOR
             END-EVALUATE
             COMPUTE WS-OVERTIME-RATE =
                 EMP-HOURLY-RATE * WS-BONUS-FACTOR
             COMPUTE WS-OVERTIME-PAY =
                 WS-OVERTIME-HOURS * WS-OVERTIME-RATE
             COMPUTE WS-GROSS-SALARY =
                 WS-REGULAR-PAY + WS-OVERTIME-PAY
         WHEN OTHER
             COMPUTE WS-REGULAR-HOURS =
                 EMP-HOURS-WORKED
             COMPUTE WS-REGULAR-PAY =
                 EMP-HOURS-WORKED * EMP-HOURLY-RATE
             MOVE WS-REGULAR-PAY TO WS-GROSS-SALARY
     END-EVALUATE.

 2150-CALCULATE-DEDUCTIONS.
     COMPUTE WS-HEALTH-DEDUCTION ROUNDED =
         WS-GROSS-SALARY * WS-HEALTH-RATE
     COMPUTE WS-RETIRE-DEDUCTION ROUNDED =
         WS-GROSS-SALARY * WS-RETIRE-RATE
     COMPUTE WS-UNEMP-DEDUCTION  ROUNDED =
         WS-GROSS-SALARY * WS-UNEMP-RATE
     COMPUTE WS-TOTAL-DEDUCTION =
         WS-HEALTH-DEDUCTION + WS-RETIRE-DEDUCTION
         + WS-UNEMP-DEDUCTION
     COMPUTE WS-NET-SALARY =
         WS-GROSS-SALARY - WS-TOTAL-DEDUCTION.

 2200-WRITE-PAYSLIP.
     MOVE EMP-ID           TO WSP-ID
     MOVE EMP-NAME         TO WSP-NAME
     MOVE EMP-CATEGORY     TO WSP-CATEGORY
     MOVE EMP-HOURS-WORKED TO WSP-HOURS
     MOVE EMP-HOURLY-RATE  TO WSP-RATE
     MOVE WS-REGULAR-PAY   TO WSP-REGULAR
     MOVE WS-OVERTIME-PAY  TO WSP-OVERTIME
     MOVE WS-GROSS-SALARY     TO WSP-GROSS
     MOVE WS-HEALTH-DEDUCTION TO WSP-HEALTH
     MOVE WS-RETIRE-DEDUCTION TO WSP-RETIREMENT
     MOVE WS-UNEMP-DEDUCTION  TO WSP-UNEMPLOYMENT
     MOVE WS-TOTAL-DEDUCTION  TO WSP-TOTAL-DED
     MOVE WS-NET-SALARY       TO WSP-NET
     WRITE PAYSLIP-RECORD FROM WS-PAYSLIP-LINE
     IF NOT PAY-FILE-OK
         DISPLAY "ERROR: Write error - Status: " WS-PAY-STATUS
     END-IF.

 2300-DISPLAY-EMPLOYEE.
     MOVE EMP-ID           TO WSD-ID
     MOVE EMP-NAME         TO WSD-NAME
     MOVE EMP-CATEGORY     TO WSD-CATEGORY
     MOVE EMP-HOURS-WORKED TO WSD-HOURS
     MOVE EMP-HOURLY-RATE  TO WSD-RATE
     MOVE WS-GROSS-SALARY  TO WSD-GROSS
     MOVE WS-NET-SALARY    TO WSD-NET
     DISPLAY WS-DISPLAY-LINE.

 2400-ACCUMULATE-CATEGORY.
     EVALUATE TRUE
         WHEN CATEGORY-A
             ADD 1 TO WS-CAT-A-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-A-PAYROLL
             ADD WS-NET-SALARY   TO WS-CAT-A-NET
         WHEN CATEGORY-B
             ADD 1 TO WS-CAT-B-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-B-PAYROLL
             ADD WS-NET-SALARY   TO WS-CAT-B-NET
         WHEN CATEGORY-C
             ADD 1 TO WS-CAT-C-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-C-PAYROLL
             ADD WS-NET-SALARY   TO WS-CAT-C-NET
         WHEN OTHER
             CONTINUE
     END-EVALUATE.

 3000-FINALIZATION.
     PERFORM 3100-BUILD-CATEGORY-TABLE
     DISPLAY WS-SEPARATOR
     MOVE WS-TOTAL-EMPLOYEES TO WS-TOT-EMP-DISP
     DISPLAY WS-TOTAL-DISP
     MOVE WS-TOTAL-REJECTED  TO WS-TOT-REJ-DISP
     DISPLAY WS-REJECTED-DISP
     MOVE WS-TOTAL-PAYROLL   TO WS-TOT-PAY-DISP
     DISPLAY WS-PAYROLL-DISP
     MOVE WS-TOTAL-NET       TO WS-TOT-NET-DISP
     DISPLAY WS-NET-PAYROLL-DISP
     DISPLAY WS-SEPARATOR
     DISPLAY "           BREAKDOWN BY JOB CATEGORY               "
     DISPLAY WS-SEPARATOR
     PERFORM 3200-DISPLAY-CATEGORY-SUMMARY
         VARYING WS-CAT-IDX FROM 1 BY 1
         UNTIL WS-CAT-IDX > 3
     DISPLAY WS-SEPARATOR
     PERFORM 3300-WRITE-REPORT-FILE
     CLOSE EMPLOYEE-FILE
     CLOSE PAYSLIP-FILE
     CLOSE REJECT-FILE
     CLOSE REPORT-FILE
     DISPLAY "JOB COMPLETED SUCCESSFULLY".

 3100-BUILD-CATEGORY-TABLE.
     MOVE "A"              TO WS-CAT-LABEL   (1)
     MOVE WS-CAT-A-COUNT  TO WS-CAT-COUNT   (1)
     MOVE WS-CAT-A-PAYROLL TO WS-CAT-TOTAL  (1)
     MOVE WS-CAT-A-NET    TO WS-CAT-NET-TOT (1)
     MOVE "B"              TO WS-CAT-LABEL   (2)
     MOVE WS-CAT-B-COUNT  TO WS-CAT-COUNT   (2)
     MOVE WS-CAT-B-PAYROLL TO WS-CAT-TOTAL  (2)
     MOVE WS-CAT-B-NET    TO WS-CAT-NET-TOT (2)
     MOVE "C"              TO WS-CAT-LABEL   (3)
     MOVE WS-CAT-C-COUNT  TO WS-CAT-COUNT   (3)
     MOVE WS-CAT-C-PAYROLL TO WS-CAT-TOTAL  (3)
     MOVE WS-CAT-C-NET    TO WS-CAT-NET-TOT (3).

 3200-DISPLAY-CATEGORY-SUMMARY.
     MOVE WS-CAT-LABEL (WS-CAT-IDX) TO WCR-LABEL
     MOVE WS-CAT-COUNT (WS-CAT-IDX) TO WCR-COUNT
     MOVE WS-CAT-TOTAL (WS-CAT-IDX) TO WCR-TOTAL
     DISPLAY WS-CAT-REPORT-LINE.

 3300-WRITE-REPORT-FILE.
     WRITE REPORT-RECORD FROM WS-RPT-HEADER
     WRITE REPORT-RECORD FROM WS-RPT-SEPARATOR
     PERFORM 3350-WRITE-REPORT-CAT-LINE
         VARYING WS-CAT-IDX FROM 1 BY 1
         UNTIL WS-CAT-IDX > 3
     WRITE REPORT-RECORD FROM WS-RPT-SEPARATOR
     PERFORM 3400-WRITE-GRAND-TOTAL
     WRITE REPORT-RECORD FROM WS-RPT-SEPARATOR.

 3350-WRITE-REPORT-CAT-LINE.
     MOVE WS-CAT-LABEL   (WS-CAT-IDX) TO WRC-LABEL
     MOVE WS-CAT-COUNT   (WS-CAT-IDX) TO WRC-COUNT
     MOVE WS-CAT-TOTAL   (WS-CAT-IDX) TO WRC-GROSS
     MOVE WS-CAT-NET-TOT (WS-CAT-IDX) TO WRC-NET
     WRITE REPORT-RECORD FROM WS-RPT-CAT-LINE
     IF NOT RPT-FILE-OK
         DISPLAY "ERROR: Report write error - Status: "
             WS-RPT-STATUS
     END-IF.

 3400-WRITE-GRAND-TOTAL.
     MOVE WS-TOTAL-EMPLOYEES TO WRG-COUNT
     MOVE WS-TOTAL-PAYROLL   TO WRG-GROSS
     MOVE WS-TOTAL-NET       TO WRG-NET
     WRITE REPORT-RECORD FROM WS-RPT-GRAND-LINE
     IF NOT RPT-FILE-OK
         DISPLAY "ERROR: Report write error - Status: "
             WS-RPT-STATUS
     END-IF.
