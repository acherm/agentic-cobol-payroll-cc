 IDENTIFICATION DIVISION.
 PROGRAM-ID. PAYROLL-SYSTEM.
 AUTHOR. PAYROLL-DEPT.

 ENVIRONMENT DIVISION.
 CONFIGURATION SECTION.
 SOURCE-COMPUTER. LINUX.
 OBJECT-COMPUTER. LINUX.
 INPUT-OUTPUT SECTION.
 FILE-CONTROL.
     SELECT EMPLOYEE-FILE
         ASSIGN TO "employees_input.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-EMP-STATUS.
     SELECT PAYSLIP-FILE
         ASSIGN TO "payslips_output.dat"
         ORGANIZATION IS LINE SEQUENTIAL
         ACCESS MODE IS SEQUENTIAL
         FILE STATUS IS WS-PAY-STATUS.

 DATA DIVISION.
 FILE SECTION.

 FD EMPLOYEE-FILE
     RECORD CONTAINS 37 CHARACTERS.
 01 EMPLOYEE-RECORD.
     05 EMP-ID              PIC 9(6).
     05 EMP-NAME            PIC X(20).
     05 EMP-CATEGORY        PIC X(1).
     05 EMP-HOURS-WORKED    PIC 9(3)V9(1).
     05 EMP-HOURLY-RATE     PIC 9(4)V9(2).

 FD PAYSLIP-FILE
     RECORD CONTAINS 73 CHARACTERS.
 01 PAYSLIP-RECORD          PIC X(73).

 WORKING-STORAGE SECTION.

 01 WS-FILE-STATUS.
     05 WS-EMP-STATUS       PIC X(2).
         88 EMP-FILE-OK     VALUE "00".
         88 EMP-EOF         VALUE "10".
     05 WS-PAY-STATUS       PIC X(2).
         88 PAY-FILE-OK     VALUE "00".

 01 WS-FLAGS.
     05 WS-END-OF-FILE      PIC X(1) VALUE "N".
         88 END-OF-FILE     VALUE "Y".
         88 NOT-END-OF-FILE VALUE "N".

 01 WS-COMPUTATION.
     05 WS-REGULAR-HOURS    PIC 9(3)V9(1) VALUE ZEROES.
     05 WS-OVERTIME-HOURS   PIC 9(3)V9(1) VALUE ZEROES.
     05 WS-REGULAR-PAY      PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-OVERTIME-PAY     PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-GROSS-SALARY     PIC 9(7)V9(2) VALUE ZEROES.
     05 WS-OVERTIME-RATE    PIC 9(4)V9(4) VALUE ZEROES.
     05 WS-BONUS-FACTOR     PIC 9(1)V9(2) VALUE ZEROES.

 01 WS-LIMITS.
     05 WS-STANDARD-HOURS   PIC 9(3)V9(1) VALUE 35.0.

 01 WS-TOTALS.
     05 WS-TOTAL-EMPLOYEES  PIC 9(6) VALUE ZEROES.
     05 WS-TOTAL-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.

 01 WS-CAT-SUBTOTALS.
     05 WS-CAT-A-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-A-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-B-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-B-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.
     05 WS-CAT-C-COUNT      PIC 9(6) VALUE ZEROES.
     05 WS-CAT-C-PAYROLL    PIC 9(9)V9(2) VALUE ZEROES.

 01 WS-CATEGORY-TABLE.
     05 WS-CAT-ENTRY OCCURS 3 TIMES INDEXED BY WS-CAT-IDX.
         10 WS-CAT-LABEL    PIC X(1).
         10 WS-CAT-COUNT    PIC 9(6).
         10 WS-CAT-TOTAL    PIC 9(9)V9(2).

 01 WS-CAT-REPORT-LINE.
     05 FILLER              PIC X(9)  VALUE "CATEGORY ".
     05 WCR-LABEL           PIC X(1).
     05 FILLER              PIC X(13) VALUE " - EMPLOYEES:".
     05 WCR-COUNT           PIC ZZ,ZZZ,ZZ9.
     05 FILLER              PIC X(9)  VALUE " PAYROLL:".
     05 WCR-TOTAL           PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-LOOP-INDEX           PIC 9(2) VALUE 1.

 01 WS-CATEGORY-FLAGS.
     05 WS-CAT              PIC X(1) VALUE SPACES.
         88 CATEGORY-A      VALUE "A".
         88 CATEGORY-B      VALUE "B".
         88 CATEGORY-C      VALUE "C".

 01 WS-PAYSLIP-LINE.
     05 WSP-ID              PIC 9(6).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-NAME            PIC X(20).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-CATEGORY        PIC X(1).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-HOURS           PIC ZZZ.9.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-RATE            PIC ZZZZ.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-REGULAR         PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-OVERTIME        PIC ZZZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSP-GROSS           PIC ZZZZZ9.99.

 01 WS-TOTAL-DISP.
     05 FILLER              PIC X(30)
         VALUE "TOTAL EMPLOYEES PROCESSED   : ".
     05 WS-TOT-EMP-DISP     PIC ZZ,ZZZ,ZZ9.

 01 WS-PAYROLL-DISP.
     05 FILLER              PIC X(30)
         VALUE "TOTAL GROSS PAYROLL         : ".
     05 WS-TOT-PAY-DISP     PIC ZZ,ZZZ,ZZZ,ZZ9.99.

 01 WS-SEPARATOR.
     05 FILLER              PIC X(60)
         VALUE "------------------------------------------------------------".

 01 WS-HEADER-LINE.
     05 FILLER              PIC X(60)
         VALUE "           PAYROLL PROCESSING REPORT                       ".

 01 WS-COL-HEADER.
     05 FILLER              PIC X(6)  VALUE "EMP-ID".
     05 FILLER              PIC X(2)  VALUE SPACES.
     05 FILLER              PIC X(20) VALUE "NAME                ".
     05 FILLER              PIC X(4)  VALUE "CAT ".
     05 FILLER              PIC X(8)  VALUE "HOURS   ".
     05 FILLER              PIC X(8)  VALUE "RATE    ".
     05 FILLER              PIC X(12) VALUE "GROSS SALARY".

 01 WS-DISPLAY-LINE.
     05 WSD-ID              PIC 9(6).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-NAME            PIC X(20).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-CATEGORY        PIC X(1).
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-HOURS           PIC ZZ9.9.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-RATE            PIC ZZZ9.99.
     05 FILLER              PIC X(1) VALUE SPACE.
     05 WSD-GROSS           PIC ZZZZ9.99.

 PROCEDURE DIVISION.

 0000-MAIN-CONTROL.
     PERFORM 1000-INITIALIZATION
     PERFORM 2000-PROCESS-EMPLOYEES
         UNTIL END-OF-FILE
     PERFORM 3000-FINALIZATION
     STOP RUN.

 1000-INITIALIZATION.
     OPEN INPUT EMPLOYEE-FILE
     IF NOT EMP-FILE-OK
         DISPLAY "ERROR: Cannot open employees_input.dat - Status: "
             WS-EMP-STATUS
         STOP RUN
     END-IF
     OPEN OUTPUT PAYSLIP-FILE
     IF NOT PAY-FILE-OK
         DISPLAY "ERROR: Cannot open payslips_output.dat - Status: "
             WS-PAY-STATUS
         STOP RUN
     END-IF
     DISPLAY WS-SEPARATOR
     DISPLAY WS-HEADER-LINE
     DISPLAY WS-SEPARATOR
     DISPLAY WS-COL-HEADER
     DISPLAY WS-SEPARATOR
     PERFORM 1100-READ-EMPLOYEE.

 1100-READ-EMPLOYEE.
     READ EMPLOYEE-FILE INTO EMPLOYEE-RECORD
     IF EMP-EOF
         MOVE "Y" TO WS-END-OF-FILE
     ELSE
         IF NOT EMP-FILE-OK
             DISPLAY "ERROR: Read error - Status: " WS-EMP-STATUS
             MOVE "Y" TO WS-END-OF-FILE
         END-IF
     END-IF.

 2000-PROCESS-EMPLOYEES.
     PERFORM 2100-CALCULATE-SALARY
     PERFORM 2200-WRITE-PAYSLIP
     PERFORM 2300-DISPLAY-EMPLOYEE
     ADD 1 TO WS-TOTAL-EMPLOYEES
     ADD WS-GROSS-SALARY TO WS-TOTAL-PAYROLL
     PERFORM 2400-ACCUMULATE-CATEGORY
     PERFORM 1100-READ-EMPLOYEE.

 2100-CALCULATE-SALARY.
     MOVE EMP-CATEGORY TO WS-CAT
     MOVE ZEROES TO WS-REGULAR-PAY
     MOVE ZEROES TO WS-OVERTIME-PAY
     MOVE ZEROES TO WS-GROSS-SALARY
     MOVE ZEROES TO WS-OVERTIME-HOURS
     MOVE ZEROES TO WS-REGULAR-HOURS
     MOVE ZEROES TO WS-BONUS-FACTOR
     EVALUATE TRUE
         WHEN EMP-HOURS-WORKED > WS-STANDARD-HOURS
             COMPUTE WS-REGULAR-HOURS =
                 WS-STANDARD-HOURS
             COMPUTE WS-OVERTIME-HOURS =
                 EMP-HOURS-WORKED - WS-STANDARD-HOURS
             COMPUTE WS-REGULAR-PAY =
                 WS-REGULAR-HOURS * EMP-HOURLY-RATE
             EVALUATE TRUE
                 WHEN CATEGORY-A
                     MOVE 1.20 TO WS-BONUS-FACTOR
                 WHEN CATEGORY-B
                     MOVE 1.10 TO WS-BONUS-FACTOR
                 WHEN CATEGORY-C
                     MOVE 1.00 TO WS-BONUS-FACTOR
                 WHEN OTHER
                     MOVE 1.00 TO WS-BONUS-FACTOR
             END-EVALUATE
             COMPUTE WS-OVERTIME-RATE =
                 EMP-HOURLY-RATE * WS-BONUS-FACTOR
             COMPUTE WS-OVERTIME-PAY =
                 WS-OVERTIME-HOURS * WS-OVERTIME-RATE
             COMPUTE WS-GROSS-SALARY =
                 WS-REGULAR-PAY + WS-OVERTIME-PAY
         WHEN OTHER
             COMPUTE WS-REGULAR-HOURS =
                 EMP-HOURS-WORKED
             COMPUTE WS-REGULAR-PAY =
                 EMP-HOURS-WORKED * EMP-HOURLY-RATE
             MOVE WS-REGULAR-PAY TO WS-GROSS-SALARY
     END-EVALUATE.

 2200-WRITE-PAYSLIP.
     MOVE EMP-ID           TO WSP-ID
     MOVE EMP-NAME         TO WSP-NAME
     MOVE EMP-CATEGORY     TO WSP-CATEGORY
     MOVE EMP-HOURS-WORKED TO WSP-HOURS
     MOVE EMP-HOURLY-RATE  TO WSP-RATE
     MOVE WS-REGULAR-PAY   TO WSP-REGULAR
     MOVE WS-OVERTIME-PAY  TO WSP-OVERTIME
     MOVE WS-GROSS-SALARY  TO WSP-GROSS
     WRITE PAYSLIP-RECORD FROM WS-PAYSLIP-LINE
     IF NOT PAY-FILE-OK
         DISPLAY "ERROR: Write error - Status: " WS-PAY-STATUS
     END-IF.

 2300-DISPLAY-EMPLOYEE.
     MOVE EMP-ID           TO WSD-ID
     MOVE EMP-NAME         TO WSD-NAME
     MOVE EMP-CATEGORY     TO WSD-CATEGORY
     MOVE EMP-HOURS-WORKED TO WSD-HOURS
     MOVE EMP-HOURLY-RATE  TO WSD-RATE
     MOVE WS-GROSS-SALARY  TO WSD-GROSS
     DISPLAY WS-DISPLAY-LINE.

 2400-ACCUMULATE-CATEGORY.
     EVALUATE TRUE
         WHEN CATEGORY-A
             ADD 1 TO WS-CAT-A-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-A-PAYROLL
         WHEN CATEGORY-B
             ADD 1 TO WS-CAT-B-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-B-PAYROLL
         WHEN CATEGORY-C
             ADD 1 TO WS-CAT-C-COUNT
             ADD WS-GROSS-SALARY TO WS-CAT-C-PAYROLL
         WHEN OTHER
             CONTINUE
     END-EVALUATE.

 3000-FINALIZATION.
     PERFORM 3100-BUILD-CATEGORY-TABLE
     DISPLAY WS-SEPARATOR
     MOVE WS-TOTAL-EMPLOYEES TO WS-TOT-EMP-DISP
     DISPLAY WS-TOTAL-DISP
     MOVE WS-TOTAL-PAYROLL   TO WS-TOT-PAY-DISP
     DISPLAY WS-PAYROLL-DISP
     DISPLAY WS-SEPARATOR
     DISPLAY "           BREAKDOWN BY JOB CATEGORY               "
     DISPLAY WS-SEPARATOR
     PERFORM 3200-DISPLAY-CATEGORY-SUMMARY
         VARYING WS-CAT-IDX FROM 1 BY 1
         UNTIL WS-CAT-IDX > 3
     DISPLAY WS-SEPARATOR
     CLOSE EMPLOYEE-FILE
     CLOSE PAYSLIP-FILE
     DISPLAY "JOB COMPLETED SUCCESSFULLY".

 3100-BUILD-CATEGORY-TABLE.
     MOVE "A"              TO WS-CAT-LABEL (1)
     MOVE WS-CAT-A-COUNT  TO WS-CAT-COUNT  (1)
     MOVE WS-CAT-A-PAYROLL TO WS-CAT-TOTAL (1)
     MOVE "B"              TO WS-CAT-LABEL (2)
     MOVE WS-CAT-B-COUNT  TO WS-CAT-COUNT  (2)
     MOVE WS-CAT-B-PAYROLL TO WS-CAT-TOTAL (2)
     MOVE "C"              TO WS-CAT-LABEL (3)
     MOVE WS-CAT-C-COUNT  TO WS-CAT-COUNT  (3)
     MOVE WS-CAT-C-PAYROLL TO WS-CAT-TOTAL (3).

 3200-DISPLAY-CATEGORY-SUMMARY.
     MOVE WS-CAT-LABEL (WS-CAT-IDX) TO WCR-LABEL
     MOVE WS-CAT-COUNT (WS-CAT-IDX) TO WCR-COUNT
     MOVE WS-CAT-TOTAL (WS-CAT-IDX) TO WCR-TOTAL
     DISPLAY WS-CAT-REPORT-LINE.
